        cursor: pointer;
        background: #ddf4ed;
        color: #1d6757;
    }

    .users-card .action-btn.approve {
        background: #e8f8f0;
        color: #1d6b45;
    }

    .status-msg {
        margin: 0 0 0.8rem;
        color: #2d5a18;
        font-weight: 600;
    }

    .status-msg.error {
        color: #9f1f38;
    }

    .account-summary-grid {
        display: flex;
        gap: 0.55rem;
        flex-wrap: wrap;
        margin-bottom: 0.85rem;
    }

    .summary-chip {
        border: 0;
        border-radius: 999px;
        padding: 0.38rem 0.7rem;
        font-size: 0.82rem;
        font-weight: 700;
        background: #eef3fb;
        color: #314056;
        cursor: pointer;
    }

    .summary-chip.is-active {
