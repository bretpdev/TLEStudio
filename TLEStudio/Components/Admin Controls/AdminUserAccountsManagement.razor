@namespace TLEStudio.Components
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using TLEStudio.Data
@using TLEStudio.Models
@using TLEStudio.Services
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject IEmailSender EmailSender
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<section class="card-block users-card">
    <div class="card-head">
        <div>
            <strong>User Accounts</strong>
            <p class="card-summary">@_accountRows.Count accounts, @_pendingCount pending, @_suspendedCount suspended</p>
        </div>
        <button type="button" class="toggle-btn" @onclick="ToggleUsers">
            @(_showUsers ? "Collapse" : "Open")
        </button>
    </div>

    @if (_showUsers)
    {
        <div class="card-body">
            <div class="account-summary-grid">
                <button type="button" class="summary-chip pending @GetChipActiveClass(AccountFilter.PendingApproval)" @onclick="() => ToggleQuickFilter(AccountFilter.PendingApproval)">Pending approval: @_pendingCount</button>
                <button type="button" class="summary-chip suspended @GetChipActiveClass(AccountFilter.Suspended)" @onclick="() => ToggleQuickFilter(AccountFilter.Suspended)">Suspended: @_suspendedCount</button>
                <button type="button" class="summary-chip verify @GetChipActiveClass(AccountFilter.NeedsVerification)" @onclick="() => ToggleQuickFilter(AccountFilter.NeedsVerification)">Needs verification: @_needsVerificationCount</button>
                <button type="button" class="summary-chip locked @GetChipActiveClass(AccountFilter.Locked)" @onclick="() => ToggleQuickFilter(AccountFilter.Locked)">Locked: @_lockedCount</button>
            </div>

            <div class="filter-toolbar">
                <div class="filter-field">
                    <label for="accountSearch">Filter accounts</label>
                    <input id="accountSearch" class="filter-input" @bind="_searchText" @bind:event="oninput" placeholder="Search by username or email" />
                </div>

                @if (_activeQuickFilter != AccountFilter.None)
                {
                    <button type="button" class="clear-filter-btn" @onclick="ClearFilters">Clear quick filter</button>
                }
            </div>

            <p class="table-hint">Select a row to edit the account.</p>

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>State</th>
                            <th>Verification</th>
                            <th>Created</th>
                            <th>Security</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var account in FilteredAccounts)
                        {
                            <tr class="account-row"
                                tabindex="0"
                                role="button"
                                aria-label="@($"Edit account {account.UserName}")"
                                @onclick="() => OpenEditModal(account)"
                                @onkeydown="args => OnRowKeyDown(args, account)">
                                <td>
                                    <div class="account-primary">
                                        <strong>@account.UserName</strong>
                                        @if (!string.IsNullOrWhiteSpace(account.Email) && !string.Equals(account.Email, account.UserName, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <small>@account.Email</small>
                                        }
                                    </div>
                                </td>
                                <td>@(account.IsAdmin ? "Admin" : "Client")</td>
                                <td><span class="state-pill @GetStateClass(account.AccountState)">@GetStateLabel(account.AccountState)</span></td>
                                <td>@(account.IsEmailVerified ? "Verified" : "Pending")</td>
                                <td>@account.CreatedUtc.ToLocalTime().ToString("MMM d, yyyy")</td>
                                <td>
                                    @if (account.LockoutEndUtc.HasValue && account.LockoutEndUtc.Value > DateTime.UtcNow)
                                    {
                                        <span class="security-flag">Locked until @account.LockoutEndUtc.Value.ToLocalTime().ToString("MMM d h:mm tt")</span>
                                    }
                                    else if (account.FailedLoginCount > 0)
                                    {
                                        <span class="security-flag">Failed logins: @account.FailedLoginCount</span>
                                    }
                                    else
                                    {
                                        <span class="security-flag is-clear">Clear</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (FilteredAccounts.Count == 0)
            {
                <p class="empty-state">No accounts match the current filters.</p>
            }
        </div>
    }
</section>

@if (_isEditModalOpen)
{
    <div class="modal-overlay" role="presentation" @onclick="CloseEditModal">
        <div class="modal-card" role="dialog" aria-modal="true" aria-label="Edit user account" @onclick:stopPropagation="true">
            <h3>Edit User Account</h3>

            @if (!string.IsNullOrWhiteSpace(_editStatusMessage))
            {
                <p class="@(_editIsError ? "status-msg error" : "status-msg")">@_editStatusMessage</p>
            }

            @if (_isEditingSelf)
            {
                <p class="modal-note">Your own account can be reviewed here, but role and access changes are disabled to prevent self-lockout.</p>
            }

            <EditForm Model="_editModel" OnValidSubmit="SaveAccountAsync" FormName="accountEditForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="edit-grid">
                    <div>
                        <label for="editUserName">Username</label>
                        <InputText id="editUserName" class="field" @bind-Value="_editModel.UserName" disabled="@_isEditingSelf" />
                    </div>
                    <div>
                        <label for="editEmail">Email</label>
                        <InputText id="editEmail" class="field" @bind-Value="_editModel.Email" />
                    </div>
                    <div>
                        <label for="editRole">Role</label>
                        <select id="editRole" class="field" @bind="_editModel.RoleName" disabled="@_isEditingSelf">
                            <option value="Client">Client</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div>
                        <label for="editState">Account state</label>
                        <select id="editState" class="field" @bind="_editModel.AccountState" disabled="@_isEditingSelf">
                            <option value="@LoginAccountStates.Active">Active</option>
                            <option value="@LoginAccountStates.PendingApproval">Pending approval</option>
                            <option value="@LoginAccountStates.Suspended">Suspended</option>
                            @if (string.Equals(_editModel.AccountState, LoginAccountStates.Denied, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@LoginAccountStates.Denied">Denied (legacy)</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="inline-field">
                    <label>
                        <InputCheckbox @bind-Value="_editModel.IsEmailVerified" />
                        <span>Email verified</span>
                    </label>
                </div>

                <div class="modal-meta-grid">
                    <div>
                        <span class="meta-label">Created</span>
                        <strong>@_editModel.CreatedDisplay</strong>
                    </div>
                    <div>
                        <span class="meta-label">Failed logins</span>
                        <strong>@_editModel.FailedLoginCount</strong>
                    </div>
                    <div>
                        <span class="meta-label">Locked until</span>
                        <strong>@(_editModel.LockoutEndsDisplay ?? "Not locked")</strong>
                    </div>
                </div>

                <div class="modal-actions secondary">
                    @if (_editModel.CanUnlock)
                    {
                        <button type="button" class="action-btn" @onclick="UnlockEditingAccountAsync">Unlock Account</button>
                    }
                    @if (_editModel.CanResendVerification)
                    {
                        <button type="button" class="action-btn" @onclick="ResendVerificationForEditingAccountAsync">Resend Verification</button>
                    }
                    @if (_editModel.CanSendPasswordReset)
                    {
                        <button type="button" class="action-btn" @onclick="SendPasswordResetForEditingAccountAsync">Send Password Reset</button>
                    }
                </div>

                <div class="modal-actions">
                    <button type="submit" class="action-btn approve">Save Changes</button>
                    <button type="button" class="action-btn" @onclick="CloseEditModal">Close</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private readonly List<LoginUser> _accountRows = [];
    private readonly AccountEditorModel _editModel = new();

    private bool _showUsers;
    private bool _isEditModalOpen;
    private bool _isEditingSelf;
    private bool _editIsError;
    private int _editingAccountId;
    private string _currentUserName = string.Empty;
    private string _searchText = string.Empty;
    private string? _editStatusMessage;
    private AccountFilter _activeQuickFilter;

    private int _pendingCount => _accountRows.Count(x => string.Equals(x.AccountState, LoginAccountStates.PendingApproval, StringComparison.OrdinalIgnoreCase));
    private int _suspendedCount => _accountRows.Count(x => string.Equals(x.AccountState, LoginAccountStates.Suspended, StringComparison.OrdinalIgnoreCase));
    private int _needsVerificationCount => _accountRows.Count(x => !x.IsEmailVerified);
    private int _lockedCount => _accountRows.Count(x => x.LockoutEndUtc.HasValue && x.LockoutEndUtc.Value > DateTime.UtcNow);
    private IReadOnlyList<LoginUser> FilteredAccounts => _accountRows
        .Where(MatchesSearch)
        .Where(MatchesQuickFilter)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUserName = authState.User.FindFirstValue(ClaimTypes.Name) ?? authState.User.Identity?.Name ?? string.Empty;
        await LoadAccountsAsync();
    }

    private void ToggleUsers()
    {
        _showUsers = !_showUsers;
    }

    private void ToggleQuickFilter(AccountFilter filter)
    {
        _activeQuickFilter = _activeQuickFilter == filter ? AccountFilter.None : filter;
    }

    private void ClearFilters()
    {
        _activeQuickFilter = AccountFilter.None;
    }

    private async Task LoadAccountsAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();

        var rows = await db.LoginUsers
            .AsNoTracking()
            .OrderByDescending(x => x.AccountState == LoginAccountStates.PendingApproval)
            .ThenByDescending(x => x.CreatedUtc)
            .ThenBy(x => x.UserName)
            .ToListAsync();

        _accountRows.Clear();
        _accountRows.AddRange(rows);
    }

    private void OpenEditModal(LoginUser account)
    {
        _editingAccountId = account.Id;
        _isEditingSelf = string.Equals(account.UserName, _currentUserName, StringComparison.OrdinalIgnoreCase);
        _editStatusMessage = null;
        _editIsError = false;

        _editModel.UserName = account.UserName;
        _editModel.Email = account.Email ?? string.Empty;
        _editModel.RoleName = account.IsAdmin ? "Admin" : "Client";
        _editModel.AccountState = account.AccountState;
        _editModel.IsEmailVerified = account.IsEmailVerified;
        _editModel.CreatedDisplay = account.CreatedUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt");
        _editModel.FailedLoginCount = account.FailedLoginCount;
        _editModel.LockoutEndsDisplay = account.LockoutEndUtc.HasValue && account.LockoutEndUtc.Value > DateTime.UtcNow
            ? account.LockoutEndUtc.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
            : null;
        _editModel.CanUnlock = account.LockoutEndUtc.HasValue && account.LockoutEndUtc.Value > DateTime.UtcNow;
        _editModel.CanResendVerification = !account.IsEmailVerified && !string.IsNullOrWhiteSpace(account.Email);
        _editModel.CanSendPasswordReset = !string.IsNullOrWhiteSpace(account.Email);

        _isEditModalOpen = true;
    }

    private void CloseEditModal()
    {
        _isEditModalOpen = false;
        _editingAccountId = 0;
        _editStatusMessage = null;
        _editIsError = false;
    }

    private void OnRowKeyDown(KeyboardEventArgs args, LoginUser account)
    {
        if (args.Key is "Enter" or " ")
        {
            OpenEditModal(account);
        }
    }

    private async Task SaveAccountAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();

        var account = await db.LoginUsers.FirstOrDefaultAsync(x => x.Id == _editingAccountId);
        if (account is null)
        {
            SetEditStatus("Account no longer exists.", true);
            return;
        }

        var newUserName = _editModel.UserName.Trim();
        var newEmail = string.IsNullOrWhiteSpace(_editModel.Email) ? null : _editModel.Email.Trim().ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(newUserName))
        {
            SetEditStatus("Username is required.", true);
            return;
        }

        if (_isEditingSelf)
        {
            newUserName = account.UserName;
            _editModel.RoleName = account.IsAdmin ? "Admin" : "Client";
            _editModel.AccountState = account.AccountState;
        }

        var normalizedUserName = newUserName.ToLowerInvariant();
        var userNameExists = await db.LoginUsers
            .AnyAsync(x => x.Id != account.Id && x.UserName.ToLower() == normalizedUserName);
        if (userNameExists)
        {
            SetEditStatus("Another account already uses that username.", true);
            return;
        }

        if (!string.IsNullOrWhiteSpace(newEmail))
        {
            var emailExists = await db.LoginUsers
                .AnyAsync(x => x.Id != account.Id && x.Email != null && x.Email.ToLower() == newEmail);
            if (emailExists)
            {
                SetEditStatus("Another account already uses that email address.", true);
                return;
            }
        }

        var previousUserName = account.UserName;
        account.UserName = newUserName;
        account.Email = newEmail;
        account.IsAdmin = string.Equals(_editModel.RoleName, "Admin", StringComparison.OrdinalIgnoreCase);
        account.AccountState = _editModel.AccountState;
        account.IsEmailVerified = _editModel.IsEmailVerified;

        if (account.IsEmailVerified)
        {
            account.EmailVerificationTokenHash = null;
            account.EmailVerificationTokenExpiresUtc = null;
        }

        if (!string.Equals(previousUserName, newUserName, StringComparison.OrdinalIgnoreCase))
        {
            var clientAppointments = await db.Appointments
                .Where(x => x.ClientUserName == previousUserName)
                .ToListAsync();

            foreach (var appointment in clientAppointments)
            {
                appointment.ClientUserName = newUserName;
            }

            var canceledAppointments = await db.Appointments
                .Where(x => x.CanceledByUserName == previousUserName)
                .ToListAsync();

            foreach (var appointment in canceledAppointments)
            {
                appointment.CanceledByUserName = newUserName;
            }
        }

        await db.SaveChangesAsync();
        await LoadAccountsAsync();
        OpenEditModal(_accountRows.First(x => x.Id == account.Id));
        SetEditStatus("Account updated.", false);
    }

    private async Task UnlockEditingAccountAsync()
    {
        await UpdateEditingAccountAsync(account =>
        {
            account.LockoutEndUtc = null;
            account.FailedLoginCount = 0;
        }, "Account lockout cleared.");
    }

    private async Task ResendVerificationForEditingAccountAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();

        var account = await db.LoginUsers.FirstOrDefaultAsync(x => x.Id == _editingAccountId);
        if (account is null)
        {
            SetEditStatus("Account no longer exists.", true);
            return;
        }

        if (account.IsEmailVerified)
        {
            SetEditStatus("This account is already verified.", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(account.Email))
        {
            SetEditStatus("This account does not have an email address to send to.", true);
            return;
        }

        var verificationToken = VerificationTokenUtility.GenerateToken();
        account.EmailVerificationTokenHash = VerificationTokenUtility.ComputeSha256Hex(verificationToken);
        account.EmailVerificationTokenExpiresUtc = DateTime.UtcNow.AddMinutes(30);

        await db.SaveChangesAsync();

        var verificationUrl = BuildVerificationUrl(verificationToken);
        var sent = await EmailSender.SendVerificationEmailAsync(account.Email, verificationUrl);
        if (!sent)
        {
            SetEditStatus("Verification email could not be sent.", true);
            return;
        }

        await LoadAccountsAsync();
        OpenEditModal(_accountRows.First(x => x.Id == account.Id));
        SetEditStatus($"Verification email resent to {account.Email}.", false);
    }

    private async Task SendPasswordResetForEditingAccountAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();

        var account = await db.LoginUsers.FirstOrDefaultAsync(x => x.Id == _editingAccountId);
        if (account is null)
        {
            SetEditStatus("Account no longer exists.", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(account.Email))
        {
            SetEditStatus("This account does not have an email address to send to.", true);
            return;
        }

        var resetToken = VerificationTokenUtility.GenerateToken();
        account.PasswordResetTokenHash = VerificationTokenUtility.ComputeSha256Hex(resetToken);
        account.PasswordResetTokenExpiresUtc = DateTime.UtcNow.AddMinutes(30);

        await db.SaveChangesAsync();

        var resetUrl = BuildResetPasswordUrl(resetToken);
        var sent = await EmailSender.SendPasswordResetEmailAsync(account.Email, resetUrl);
        if (!sent)
        {
            SetEditStatus("Password reset email could not be sent.", true);
            return;
        }

        await LoadAccountsAsync();
        OpenEditModal(_accountRows.First(x => x.Id == account.Id));
        SetEditStatus($"Password reset email sent to {account.Email}.", false);
    }

    private async Task UpdateEditingAccountAsync(Action<LoginUser> updateAction, string successMessage)
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();

        var account = await db.LoginUsers.FirstOrDefaultAsync(x => x.Id == _editingAccountId);
        if (account is null)
        {
            SetEditStatus("Account no longer exists.", true);
            return;
        }

        updateAction(account);
        await db.SaveChangesAsync();

        await LoadAccountsAsync();
        OpenEditModal(_accountRows.First(x => x.Id == account.Id));
        SetEditStatus(successMessage, false);
    }

    private bool MatchesSearch(LoginUser account)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        return account.UserName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || (!string.IsNullOrWhiteSpace(account.Email) && account.Email.Contains(_searchText, StringComparison.OrdinalIgnoreCase));
    }

    private bool MatchesQuickFilter(LoginUser account)
    {
        return _activeQuickFilter switch
        {
            AccountFilter.PendingApproval => string.Equals(account.AccountState, LoginAccountStates.PendingApproval, StringComparison.OrdinalIgnoreCase),
            AccountFilter.Suspended => string.Equals(account.AccountState, LoginAccountStates.Suspended, StringComparison.OrdinalIgnoreCase),
            AccountFilter.NeedsVerification => !account.IsEmailVerified,
            AccountFilter.Locked => account.LockoutEndUtc.HasValue && account.LockoutEndUtc.Value > DateTime.UtcNow,
            _ => true
        };
    }

    private string GetChipActiveClass(AccountFilter filter)
    {
        return _activeQuickFilter == filter ? "is-active" : string.Empty;
    }

    private static string GetStateLabel(string accountState)
    {
        return accountState switch
        {
            LoginAccountStates.PendingApproval => "Pending approval",
            LoginAccountStates.Suspended => "Suspended",
            LoginAccountStates.Denied => "Denied",
            _ => "Active"
        };
    }

    private static string GetStateClass(string accountState)
    {
        return accountState switch
        {
            LoginAccountStates.PendingApproval => "pending",
            LoginAccountStates.Suspended => "suspended",
            LoginAccountStates.Denied => "denied",
            _ => "active"
        };
    }

    private string BuildVerificationUrl(string token)
    {
        return $"{NavigationManager.BaseUri.TrimEnd('/')}/auth/verify-email?token={Uri.EscapeDataString(token)}";
    }

    private string BuildResetPasswordUrl(string token)
    {
        return $"{NavigationManager.BaseUri.TrimEnd('/')}/reset-password?token={Uri.EscapeDataString(token)}";
    }

    private void SetEditStatus(string message, bool isError)
    {
        _editStatusMessage = message;
        _editIsError = isError;
    }

    private enum AccountFilter
    {
        None,
        PendingApproval,
        Suspended,
        NeedsVerification,
        Locked
    }

    private sealed class AccountEditorModel
    {
        [Required]
        public string UserName { get; set; } = string.Empty;

        public string Email { get; set; } = string.Empty;

        public string RoleName { get; set; } = "Client";

        public string AccountState { get; set; } = LoginAccountStates.Active;

        public bool IsEmailVerified { get; set; }

        public string CreatedDisplay { get; set; } = string.Empty;

        public int FailedLoginCount { get; set; }

        public string? LockoutEndsDisplay { get; set; }

        public bool CanUnlock { get; set; }

        public bool CanResendVerification { get; set; }

        public bool CanSendPasswordReset { get; set; }
    }
}

<style>
