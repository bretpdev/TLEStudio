        display: grid;
        gap: 0.3rem;
        min-width: 280px;
    }

    .filter-field label,
    .edit-grid label,
    .meta-label {
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #7a8290;
    }

    .filter-input,
    .field {
        border: 1px solid #d7dce6;
