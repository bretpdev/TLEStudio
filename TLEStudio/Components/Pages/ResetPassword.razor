@page "/reset-password"
@inject NavigationManager NavigationManager

<PageTitle>Reset Password</PageTitle>

<div class="reset-shell">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 col-xl-5">
            <div class="card shadow-sm border-0 reset-card">
                <div class="card-header reset-card-header">
                    <p class="auth-eyebrow">Account Recovery</p>
                    <h1>@(_hasToken ? "Choose a new password" : "Reset your password")</h1>
                    <p class="auth-subtitle">@(_hasToken ? "Set a new password for your TLE Studio account." : "Enter your email and we will send you a password reset link.")</p>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrWhiteSpace(_message))
                    {
                        <div class="alert @(_isError ? "alert-danger" : "alert-success") d-flex align-items-center mb-4" role="alert">
                            <span>@_message</span>
                        </div>
                    }

                    @if (_showRequestForm)
                    {
                        <form method="post" action="/auth/request-password-reset">
                            <div class="form-group mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input id="email" name="email" type="email" class="form-control" minlength="6" maxlength="256" required />
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn auth-btn">Send reset link</button>
                            </div>
                        </form>
                    }
                    else if (_showResetForm)
                    {
                        <form method="post" action="/auth/reset-password">
                            <input type="hidden" name="token" value="@_token" />

                            <div class="form-group mb-3">
                                <label for="password" class="form-label">New password</label>
                                <input id="password" name="password" type="password" class="form-control" minlength="12" required />
                                <small class="form-text text-muted">Use at least 12 characters with upper, lower, number, and symbol.</small>
                            </div>

                            <div class="form-group mb-3">
                                <label for="confirmPassword" class="form-label">Confirm new password</label>
                                <input id="confirmPassword" name="confirmPassword" type="password" class="form-control" minlength="12" required />
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn auth-btn">Reset password</button>
                            </div>
                        </form>
                    }

                    <div class="auth-help">
                        <p><a class="text-link" href="/login">Back to login</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _hasToken;
    private bool _isError;
    private bool _showRequestForm = true;
    private bool _showResetForm;
    private string _token = string.Empty;
    private string? _message;

    protected override void OnInitialized()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("token", out var token))
        {
            _token = token.ToString();
            _hasToken = !string.IsNullOrWhiteSpace(_token);
        }

        if (_hasToken)
        {
            _showRequestForm = false;
            _showResetForm = true;
        }

        if (query.TryGetValue("requested", out var requestedFlag) && requestedFlag.ToString() == "1")
        {
            _isError = false;
            _showRequestForm = true;
            _showResetForm = false;
            _message = "If an account exists for that email, a password reset link has been sent.";
            return;
        }

        if (!query.TryGetValue("error", out var errorCode))
        {
            return;
        }

        _isError = true;
        _message = errorCode.ToString() switch
        {
            "disabled" => "Password reset email is not configured right now.",
            "invalid_email" => "Enter a valid email address.",
            "email_send_failed" => "We could not send the password reset email. Please try again in a moment.",
            "weak_password" => "Password must be 12+ characters and include upper, lower, number, and symbol.",
            "password_mismatch" => "Password and confirmation do not match.",
            "expired" => "This password reset link has expired.",
            _ => "This password reset link is invalid."
        };

        if (_hasToken)
        {
            _showRequestForm = false;
            _showResetForm = errorCode.ToString() is not "expired" and not "invalid";
        }
        else
        {
            _showRequestForm = true;
            _showResetForm = false;
        }
    }
}

<style>
    .reset-shell {
        width: min(980px, 94vw);
        margin: 0 auto;
        padding: 3.2rem 0 4rem;
    }

    .reset-card {
        background: #fff;
        border: 1px solid #eceff4;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 18px 42px rgba(31, 36, 48, 0.11);
    }

    .reset-card-header {
        background: linear-gradient(140deg, rgba(232, 213, 183, 0.35), rgba(255, 255, 255, 0.95));
        padding: 1.15rem 1.3rem;
        border-bottom: 1px solid #eceff4;
    }

    .auth-eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #84662b;
        font-size: 0.74rem;
        margin-bottom: 0.6rem;
        font-weight: 700;
    }

    .reset-card h1 {
        font-family: "Fraunces", Georgia, serif;
        font-size: clamp(1.35rem, 3.2vw, 1.9rem);
        margin: 0;
    }

    .auth-subtitle {
        color: #5f6672;
        line-height: 1.6;
        margin: 0.5rem 0 0;
        font-size: 0.95rem;
    }

    .form-label {
        font-weight: 600;
        color: #1f2430;
    }

    .form-control {
        border: 1px solid #d7dce6;
        border-radius: 12px;
        padding: 0.75rem 0.85rem;
    }

    .form-control:focus {
        border-color: #84662b;
        box-shadow: 0 0 0 0.2rem rgba(132, 102, 43, 0.16);
    }

    .auth-btn {
        margin-top: 0.25rem;
        border: 0;
        border-radius: 999px;
        padding: 0.72rem 1rem;
        background: linear-gradient(135deg, #ff6a5b, #ff4f7b);
        color: #fff;
        font-weight: 700;
        cursor: pointer;
    }

    .auth-help {
        margin-top: 1rem;
        border-top: 1px solid #eceff4;
        padding-top: 0.8rem;
        color: #5f6672;
        font-size: 0.88rem;
    }

    .auth-help p {
        margin: 0;
    }
</style>