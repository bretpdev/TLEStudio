@page "/admin-dashboard"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin Dashboard</PageTitle>

<div class="admin-page">
    <header class="admin-head">
        <p class="admin-label">Admin</p>
        <h1>Dashboard</h1>
        <p>Set up services with price and duration for client booking.</p>
    </header>

    <AdminServicesManagement />
    <AdminTimeManagement />
    <AdminUserAccountsManagement />

    <AdminCanceledAppointments />
</div>

<style>
    .admin-page {
        width: min(1080px, 94vw);
        margin: 0 auto;
        padding: 2.3rem 0 4rem;
    }

    .admin-label {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
        font-weight: 700;
        color: #84662b;
        margin-bottom: 0.55rem;
    }

    .admin-head h1 {
        font-family: "Fraunces", Georgia, serif;
        margin: 0;
    }

    .admin-head p {
        color: #5f6672;
        margin-top: 0.55rem;
    }

</style>
