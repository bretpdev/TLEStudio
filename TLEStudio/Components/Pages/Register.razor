@page "/register"
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration

<PageTitle>Create Account</PageTitle>

<div class="register-shell">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 col-xl-5">
            <div class="card shadow-sm border-0 register-card">
                <div class="card-header register-card-header">
                    <p class="auth-eyebrow">New Client</p>
                    <h1>Create your account</h1>
                    <p class="auth-subtitle">Create a secure account so you can manage your appointments online.</p>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrWhiteSpace(_message))
                    {
                        <div class="alert @(_isError ? "alert-danger" : "alert-success") d-flex align-items-center mb-4" role="alert">
                            <span>@_message</span>
                        </div>
                    }

                    @if (_registrationEnabled)
                    {
                        <form method="post" action="/auth/register">
                            <div class="form-group mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input id="email" name="email" type="email" class="form-control" minlength="6" maxlength="256" required />
                            </div>

                            <div class="form-group mb-3">
                                <label for="password" class="form-label">Password</label>
                                <input id="password" name="password" type="password" class="form-control" minlength="12" required />
                                <small class="form-text text-muted">Use at least 12 characters with upper, lower, number, and symbol.</small>
                            </div>

                            <div class="form-group mb-3">
                                <label for="confirmPassword" class="form-label">Confirm Password</label>
                                <input id="confirmPassword" name="confirmPassword" type="password" class="form-control" minlength="12" required />
                            </div>

                            <div class="honeypot" aria-hidden="true">
                                <label for="website">Website</label>
                                <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_turnstileSiteKey))
                            {
                                <div class="mb-3">
                                    <div class="cf-turnstile" data-sitekey="@_turnstileSiteKey"></div>
                                </div>
                            }

                            <input type="hidden" name="returnUrl" value="@_returnUrl" />

                            <div class="d-grid">
                                <button type="submit" class="btn auth-btn">Create account</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-warning" role="alert">
                            Online signup is temporarily disabled.
                        </div>
                    }

                    <div class="auth-help">
                        <p>Already registered? <a class="text-link" href="/login">Sign in</a>.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_turnstileSiteKey))
{
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
}

@code {
    private string _returnUrl = "/calendar";
    private string? _message;
    private bool _isError;
    private bool _registrationEnabled;
    private string? _turnstileSiteKey;

    protected override void OnInitialized()
    {
        _turnstileSiteKey = Configuration["Turnstile:SiteKey"];
        var turnstileSecretKey = Configuration["Turnstile:SecretKey"];
        var smtpHost = Configuration["Email:Smtp:Host"];
        var smtpFrom = Configuration["Email:Smtp:From"];
        _registrationEnabled =
            !string.IsNullOrWhiteSpace(turnstileSecretKey) &&
            !string.IsNullOrWhiteSpace(_turnstileSiteKey) &&
            !string.IsNullOrWhiteSpace(smtpHost) &&
            !string.IsNullOrWhiteSpace(smtpFrom);

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("returnUrl", out var returnUrl) && !string.IsNullOrWhiteSpace(returnUrl))
        {
            _returnUrl = returnUrl.ToString();
        }

        if (!query.TryGetValue("error", out var errorCode))
        {
            if (query.TryGetValue("success", out var success) && success.ToString() == "1")
            {
                _isError = false;
                _message = "Account created. Please sign in.";
            }

            return;
        }

        _isError = true;
        _message = errorCode.ToString() switch
        {
            "disabled" => "Registration is disabled until anti-bot security is configured.",
            "invalid_email" => "Enter a valid email address.",
            "weak_password" => "Password must be 12+ characters and include upper, lower, number, and symbol.",
            "password_mismatch" => "Password and confirmation do not match.",
            "captcha" => "Security challenge failed. Please try again.",
            "exists" => "An account with that email already exists.",
            "email_send_failed" => "We could not send the verification email. Please try again in a moment.",
            _ => "Registration could not be completed. Please try again."
        };
    }
}

<style>
    .register-shell {
        width: min(980px, 94vw);
        margin: 0 auto;
        padding: 3.2rem 0 4rem;
    }

    .register-card {
        background: #fff;
        border: 1px solid #eceff4;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 18px 42px rgba(31, 36, 48, 0.11);
    }

    .register-card-header {
        background: linear-gradient(140deg, rgba(232, 213, 183, 0.35), rgba(255, 255, 255, 0.95));
        padding: 1.15rem 1.3rem;
        border-bottom: 1px solid #eceff4;
    }

    .auth-eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #84662b;
        font-size: 0.74rem;
        margin-bottom: 0.6rem;
        font-weight: 700;
    }

    .register-card h1 {
        font-family: "Fraunces", Georgia, serif;
        font-size: clamp(1.35rem, 3.2vw, 1.9rem);
        margin: 0;
    }

    .auth-subtitle {
        color: #5f6672;
        line-height: 1.6;
        margin: 0.5rem 0 0;
        font-size: 0.95rem;
    }

    .form-label {
        font-weight: 600;
        color: #1f2430;
    }

    .form-control {
        border: 1px solid #d7dce6;
        border-radius: 12px;
        padding: 0.75rem 0.85rem;
    }

    .form-control:focus {
        border-color: #84662b;
        box-shadow: 0 0 0 0.2rem rgba(132, 102, 43, 0.16);
    }

    .auth-btn {
        margin-top: 0.25rem;
        border: 0;
        border-radius: 999px;
        padding: 0.72rem 1rem;
        background: linear-gradient(135deg, #ff6a5b, #ff4f7b);
        color: #fff;
        font-weight: 700;
        cursor: pointer;
    }

    .honeypot {
        position: absolute;
        left: -10000px;
        width: 1px;
        height: 1px;
        overflow: hidden;
    }

    .auth-help {
        margin-top: 1rem;
        border-top: 1px solid #eceff4;
        padding-top: 0.8rem;
        color: #5f6672;
        font-size: 0.88rem;
    }

    .auth-help p {
        margin: 0;
    }
</style>
