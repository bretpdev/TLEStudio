@page "/calendar"
@attribute [Authorize]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using TLEStudio.Data
@using TLEStudio.Models
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AppDbContext DbContext
@inject IJSRuntime JS

<PageTitle>Availability Calendar</PageTitle>

<div class="calendar-page">
    <header class="calendar-head">
        <h1>Manage Appointments</h1>
    </header>

    @if (!string.IsNullOrWhiteSpace(_bookingMessage))
    {
        <p class="booking-message">@_bookingMessage</p>
    }

    @if (!_isAdmin)
    {
        <section class="client-bookings-toggle" role="tablist" aria-label="Client booking history options">
            <button type="button"
                    role="tab"
                    class="@GetClientBookingViewButtonClass(ClientBookingView.Upcoming)"
                    aria-selected="@(_clientBookingView == ClientBookingView.Upcoming)"
                    @onclick="() => _clientBookingView = ClientBookingView.Upcoming">
                Upcoming Appointments
            </button>
            <button type="button"
                    role="tab"
                    class="@GetClientBookingViewButtonClass(ClientBookingView.Past)"
                    aria-selected="@(_clientBookingView == ClientBookingView.Past)"
                    @onclick="() => _clientBookingView = ClientBookingView.Past">
                Past Appointments
            </button>
        </section>

        @if (_clientBookingView == ClientBookingView.Upcoming)
        {
            <section class="my-bookings">
                <h2> Appointments</h2>

                @if (_myAppointments.Count == 0)
                {
                    <p class="my-bookings-empty">You do not have any booked appointments yet.</p>
                }
                else
                {
                    <ul>
                        @foreach (var booking in _myAppointments)
                        {
                            <li>
                                <strong>@booking.ServiceName</strong>
                                <span>@booking.Start.ToString("dddd, MMM d")</span>
                                <span>@booking.Start.ToString("h:mm tt") - @booking.End.ToString("h:mm tt")</span>
                                <a class="download-ics-link" href="@($"/appointments/{booking.AppointmentId}/download.ics")">Add to Calendar</a>
                                <button type="button" class="cancel-booking-btn" @onclick="() => CancelAppointmentAsync(booking.AppointmentId)">Cancel</button>
                            </li>
                        }
                    </ul>
                }
            </section>
        }
        else
        {
            <section class="agenda-wrap client-past-appointments">
                <h2>Your Past Appointments</h2>

                @if (_pastClientAppointments.Count == 0)
                {
                    <p class="agenda-empty">No past appointments found.</p>
                }
                else
                {
                    <ul class="agenda-list">
                        @foreach (var item in PagedPastClientAppointments)
                        {
                            <li>
                                <div class="agenda-primary">
                                    <strong>@item.Start.ToString("dddd, MMM d")</strong>
                                    <span>@item.Start.ToString("h:mm tt") - @item.End.ToString("h:mm tt")</span>
                                    <small>@item.Label</small>
                                </div>
                            </li>
                        }
                    </ul>

                    @if (PastAppointmentsTotalPages > 1)
                    {
                        <div class="past-appointments-paging">
                            <button type="button"
                                    class="toggle-btn"
                                    @onclick="PreviousPastAppointmentsPage"
                                    disabled="@(_pastClientAppointmentsPage == 1)">
                                Previous
                            </button>
                            <span>Page @_pastClientAppointmentsPage of @PastAppointmentsTotalPages</span>
                            <button type="button"
                                    class="toggle-btn"
                                    @onclick="NextPastAppointmentsPage"
                                    disabled="@(_pastClientAppointmentsPage >= PastAppointmentsTotalPages)">
                                Next
                            </button>
                        </div>
                    }
                }
            </section>
        }
    }

    <section class="calendar-toolbar">
        <div class="range-nav">
            <button type="button"
                    class="range-nav-btn"
                    @onclick="() => ShiftRangeAsync(-7)"
                    disabled="@(!_isAdmin && IsClientAtCurrentWeek())">
                Previous Week
            </button>
            <button type="button" class="range-nav-btn" @onclick="() => ShiftRangeAsync(7)">Next Week</button>
        </div>

        <div class="calendar-range">
            <span>Showing</span>
            <strong>@_rangeStart.ToString("MMM d, yyyy") - @_rangeEnd.ToString("MMM d, yyyy")</strong>
        </div>

        @if (!_isAdmin)
        {
            <div class="service-picker">
                <label for="servicePicker">Service</label>
                <select id="servicePicker" @bind="_selectedServiceId" @bind:after="OnServiceChangedAsync">
                    <option value="0">-- Select a Service --</option>
                    @foreach (var service in _services)
                    {
                        <option value="@service.Id">@service.Name (@service.DurationMinutes min, @service.Price.ToString("C"))</option>
                    }
                </select>
            </div>
        }

        @if (_isAdmin)
        {
            <div class="view-toggle" role="tablist" aria-label="Calendar view options">
                <button type="button"
                        role="tab"
                        class="@GetViewButtonClass(CalendarView.Calendar)"
                        aria-selected="@(_selectedView == CalendarView.Calendar)"
                        @onclick="() => _selectedView = CalendarView.Calendar">
                    Calendar View
                </button>
                <button type="button"
                        role="tab"
                        class="@GetViewButtonClass(CalendarView.Agenda)"
                        aria-selected="@(_selectedView == CalendarView.Agenda)"
                        @onclick="() => _selectedView = CalendarView.Agenda">
                    Agenda View
                </button>
            </div>
        }
    </section>

    @if (_selectedView == CalendarView.Calendar)
    {
        <section class="calendar-grid-wrap">
            <div class="calendar-grid-scroll">
                <div class="calendar-grid-header">
                    @foreach (var dayName in _dayNames)
                    {
                        <div>@dayName</div>
                    }

                    <AdminAppointmentManager
                        IsOpen="@_isAdminManageModalOpen"
                        @bind-SelectedStart="_adminManageStart"
                        AppointmentId="@_adminManageAppointmentId"
                        @bind-SelectedClientId="_adminSelectedClientId"
                        @bind-SelectedServiceId="_adminManageServiceId"
                        EndPreviewText="@GetAdminManageEndPreview()"
                        Message="@_adminManageMessage"
                        Clients="_clients"
                        Services="_services"
                        OnSave="SaveAdminManagedAppointmentAsync"
                        OnCancelAppointment="CancelAdminManagedAppointmentAsync"
                        OnClose="CloseAdminManageModal" />
                </div>

                <div class="calendar-grid-body">
                    @foreach (var week in _weeks)
                    {
                        <div class="calendar-week-row">
                            @foreach (var day in week)
                            {
                                var eventsForDay = GetEventsForDay(day);
                                var bookedForDay = _isAdmin ? GetAdminAppointmentsForDay(day) : [];
                                <article class="@GetDayClass(day)">
                                    <header>
                                        <span class="day-name">@day.ToString("ddd")</span>
                                        <strong>@day.ToString("MMM d")</strong>
                                    </header>

                                    @if (!IsWithinRange(day))
                                    {
                                        <p class="off-range">Outside selected range</p>
                                    }
                                    else if (eventsForDay.Count == 0 && bookedForDay.Count == 0)
                                    {
                                        <p class="no-openings">@(_isAdmin ? "No open blocks" : "No open blocks for selected service duration")</p>
                                    }
                                    else
                                    {
                                        <ul>
                                            @foreach (var ev in eventsForDay)
                                            {
                                                <li>
                                                    <span>@ev.Start.ToString("h:mm tt") - @ev.End.ToString("h:mm tt")</span>
                                                    @if (!_isAdmin)
                                                    {
                                                        <button type="button" class="book-btn" @onclick="() => BookAppointmentAsync(ev)">Book</button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="manage-btn" @onclick="() => BeginAdminManageOpenAsync(ev)">Manage</button>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }

                                    @if (_isAdmin)
                                    {
                                        if (bookedForDay.Count > 0)
                                        {
                                            var hideBookedDivider = eventsForDay.Count == 0 && bookedForDay.Count == 1;
                                            <div class="@(hideBookedDivider ? "admin-booked-group no-divider" : "admin-booked-group")">
                                                <p class="admin-booked-title">Booked</p>
                                                <ul class="admin-booked-list">
                                                    @foreach (var booking in bookedForDay)
                                                    {
                                                        <li>
                                                            <span>@booking.Start.ToString("h:mm tt") - @booking.End.ToString("h:mm tt")</span>
                                                            <small>@booking.ServiceName</small>
                                                            <em>Client: @booking.ClientUserName</em>
                                                            <button type="button" class="manage-btn" @onclick="() => BeginAdminManageExistingAsync(booking)">Manage</button>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                    }
                                </article>
                            }
                        </div>
                    }
                </div>
            </div>
        </section>
    }
    else
    {
        <section class="agenda-wrap">
            <h2>Agenda</h2>

            @if (_agendaItems.Count == 0)
            {
                <p class="agenda-empty">No booked appointments in this date range.</p>
            }
            else
            {
                <ul class="agenda-list">
                    @foreach (var item in _agendaItems)
                    {
                        <li>
                            <div class="agenda-primary">
                                <strong>@item.Start.ToString("dddd, MMM d")</strong>
                                <span>@item.Start.ToString("h:mm tt") - @item.End.ToString("h:mm tt")</span>
                                <small>Duration: @item.DurationMinutes min</small>
                            </div>
                            <div class="agenda-action">
                                <em>@item.Label</em>
                                @if (_isAdmin && !string.IsNullOrWhiteSpace(item.ClientUserName))
                                {
                                    <small>Client: @item.ClientUserName</small>
                                    <button type="button" class="manage-btn" @onclick="() => BeginAdminManageExistingAsync(item)">Manage</button>
                                }
                            </div>
                        </li>
                    }
                </ul>
            }
        </section>
    }

</div>

@code {
    private readonly string[] _dayNames = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
    private readonly List<AvailabilityEvent> _events = [];
    private readonly List<List<DateOnly>> _weeks = [];
    private readonly List<ServiceOffering> _services = [];
    private readonly List<LoginUser> _clients = [];

    private DateOnly _rangeStart;
    private DateOnly _rangeEnd;
    private CalendarView _selectedView = CalendarView.Calendar;
    private int _selectedServiceId;
    private bool _isAdmin;
    private bool _isAdminManageModalOpen;
    private string _currentUserName = string.Empty;
    private string? _bookingMessage;
    private int? _adminManageAppointmentId;
    private DateTime? _adminManageStart;
    private int _adminSelectedClientId;
    private int _adminManageServiceId;
    private string? _adminManageMessage;
    private ClientBookingView _clientBookingView = ClientBookingView.Upcoming;
    private bool _restoreScrollAfterShift;
    private int _pastClientAppointmentsPage = 1;

    private List<AgendaBookingItem> _agendaItems = [];
    private List<ClientBookingBlock> _myAppointments = [];
    private List<AdminBookedAppointment> _adminBookedAppointments = [];
    private List<AgendaBookingItem> _pastClientAppointments = [];
    private const int PastAppointmentsPageSize = 10;
    private int PastAppointmentsTotalPages => Math.Max(1, (int)Math.Ceiling(_pastClientAppointments.Count / (double)PastAppointmentsPageSize));
    private IReadOnlyList<AgendaBookingItem> PagedPastClientAppointments => _pastClientAppointments
        .Skip((_pastClientAppointmentsPage - 1) * PastAppointmentsPageSize)
        .Take(PastAppointmentsPageSize)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        await DetermineRoleAsync();

        _rangeStart = StartOfBusinessWeek(today);
        _rangeEnd = _rangeStart.AddDays(13);

        await LoadServicesAsync();
        BuildWeeks();
        await LoadAvailabilityAsync();

        if (!_isAdmin)
        {
            await LoadClientAppointmentsAsync();
            await LoadPastClientAppointmentsAsync();
        }

        if (_isAdmin)
        {
            await LoadClientsAsync();
            await LoadAdminBookedAppointmentsAsync();
        }
        else
        {
            _selectedView = CalendarView.Calendar;
        }
    }

    private async Task ShiftRangeAsync(int dayOffset)
    {
        await JS.InvokeVoidAsync("tleStudioScroll.capture");

        var nextStart = _rangeStart.AddDays(dayOffset);
        var nextEnd = nextStart.AddDays(13);

        if (!_isAdmin)
        {
            var currentWeekStart = StartOfBusinessWeek(DateOnly.FromDateTime(DateTime.Today));
            if (nextStart < currentWeekStart)
            {
                return;
            }
        }

        _rangeStart = nextStart;
        _rangeEnd = nextEnd;

        BuildWeeks();
        await LoadAvailabilityAsync();

        if (_isAdmin)
        {
            await LoadAdminBookedAppointmentsAsync();
        }

        _restoreScrollAfterShift = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_restoreScrollAfterShift)
        {
            _restoreScrollAfterShift = false;
            await JS.InvokeVoidAsync("tleStudioScroll.restore");
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private void BuildWeeks()
    {
        _weeks.Clear();

        for (var weekStart = _rangeStart; weekStart <= _rangeEnd; weekStart = weekStart.AddDays(7))
        {
            var week = new List<DateOnly>(6);
            for (var i = 0; i < 6; i++)
            {
                week.Add(weekStart.AddDays(i));
            }

            _weeks.Add(week);
        }
    }

    private async Task DetermineRoleAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole("Admin") || authState.User.Claims.Any(x => x.Type == ClaimTypes.Role && x.Value == "Admin");
        _currentUserName = authState.User.Identity?.Name ?? string.Empty;
    }

    private async Task LoadServicesAsync()
    {
        _services.Clear();

        var rows = await DbContext.ServiceOfferings
            .AsNoTracking()
            .Where(x => x.IsActive)
            .OrderBy(x => x.Name)
            .ToListAsync();

        _services.AddRange(rows);

        if (_services.Count == 0)
        {
            _selectedServiceId = 0;
            return;
        }

        if (_services.All(x => x.Id != _selectedServiceId))
        {
            _selectedServiceId = _isAdmin ? _services[0].Id : 0;
        }

        if (_adminManageServiceId == 0 && _services.Count > 0)
        {
            _adminManageServiceId = _services[0].Id;
        }
    }

    private async Task LoadClientsAsync()
    {
        _clients.Clear();

        var rows = await DbContext.LoginUsers
            .AsNoTracking()
            .Where(x => !x.IsAdmin)
            .OrderBy(x => x.UserName)
            .ToListAsync();

        _clients.AddRange(rows);

        if (_adminSelectedClientId == 0 && _clients.Count > 0)
        {
            _adminSelectedClientId = _clients[0].Id;
        }
    }

    private async Task OnServiceChangedAsync()
    {
        await LoadAvailabilityAsync();
    }

    private async Task LoadAvailabilityAsync()
    {
        _events.Clear();
        _agendaItems = [];

        var selectedService = _services.FirstOrDefault(x => x.Id == _selectedServiceId);
        if (!_isAdmin && selectedService is null)
        {
            return;
        }

        var rangeStart = _rangeStart.ToDateTime(TimeOnly.MinValue);
        var rangeEndExclusive = _rangeEnd.AddDays(1).ToDateTime(TimeOnly.MinValue);

        await EnsureAvailabilityForRangeAsync();

        var availabilityRows = await DbContext.AvailabilityHours
            .AsNoTracking()
            .Where(x => x.SlotStart >= rangeStart && x.SlotStart < rangeEndExclusive)
            .OrderBy(x => x.SlotStart)
            .ToListAsync();

        var appointmentRows = await DbContext.Appointments
            .AsNoTracking()
            .Where(x => x.Status == "Booked")
            .Where(x => x.StartTime < rangeEndExclusive && x.EndTime > rangeStart)
            .ToListAsync();

        var blockedStarts = new HashSet<DateTime>();
        foreach (var appointment in appointmentRows)
        {
            for (var cursor = appointment.StartTime; cursor < appointment.EndTime; cursor = cursor.AddHours(1))
            {
                blockedStarts.Add(cursor);
            }
        }

        var freeStarts = availabilityRows
            .Where(x => DateOnly.FromDateTime(x.SlotStart).DayOfWeek != DayOfWeek.Sunday)
            .Select(x => x.SlotStart)
            .Where(x => !blockedStarts.Contains(x))
            .Where(x => x >= DateTime.Now)
            .Distinct()
            .OrderBy(x => x)
            .ToList();

        var freeByDay = freeStarts
            .GroupBy(x => DateOnly.FromDateTime(x))
            .ToDictionary(x => x.Key, x => x.ToHashSet());

        if (_isAdmin)
        {
            _events.AddRange(BuildOpeningsForAdmin(freeByDay));
        }
        else
        {
            _events.AddRange(BuildOpeningsForService(selectedService!, freeByDay));
        }

        _events.Sort((a, b) => a.Start.CompareTo(b.Start));
        await LoadAgendaItemsAsync(rangeStart, rangeEndExclusive);
    }

    private async Task EnsureAvailabilityForRangeAsync()
    {
        var rangeStart = _rangeStart.ToDateTime(TimeOnly.MinValue);
        var rangeEndExclusive = _rangeEnd.AddDays(1).ToDateTime(TimeOnly.MinValue);

        var overrideDates = await DbContext.DayAvailabilityOverrides
            .AsNoTracking()
            .Where(x => x.OverrideDate >= _rangeStart && x.OverrideDate <= _rangeEnd)
            .Select(x => x.OverrideDate)
            .ToListAsync();

        var existingDates = await DbContext.AvailabilityHours
            .AsNoTracking()
            .Where(x => x.SlotStart >= rangeStart && x.SlotStart < rangeEndExclusive)
            .Select(x => DateOnly.FromDateTime(x.SlotStart))
            .Distinct()
            .ToListAsync();

        var overrideDateSet = overrideDates.ToHashSet();
        var existingDateSet = existingDates.ToHashSet();
        var rules = await DbContext.WeeklyAvailabilityRules
            .AsNoTracking()
            .Where(x => x.IsOpen)
            .ToListAsync();
        var rulesByDay = rules.ToDictionary(x => x.DayOfWeekNumber);

        var addedAny = false;

        for (var day = _rangeStart; day <= _rangeEnd; day = day.AddDays(1))
        {
            if (day < DateOnly.FromDateTime(DateTime.Today) ||
                day.DayOfWeek == DayOfWeek.Sunday ||
                existingDateSet.Contains(day) ||
                overrideDateSet.Contains(day))
            {
                continue;
            }

            if (!rulesByDay.TryGetValue((int)day.DayOfWeek, out var rule) || rule.EndHour <= rule.StartHour)
            {
                continue;
            }

            for (var hour = rule.StartHour; hour < rule.EndHour; hour++)
            {
                var start = day.ToDateTime(new TimeOnly(hour, 0));
                DbContext.AvailabilityHours.Add(new AvailabilityHour
                {
                    SlotStart = start,
                    SlotEnd = start.AddHours(1)
                });
            }

            addedAny = true;
        }

        if (addedAny)
        {
            await DbContext.SaveChangesAsync();
        }
    }

    private async Task LoadAgendaItemsAsync(DateTime rangeStart, DateTime rangeEndExclusive)
    {
        var query = DbContext.Appointments
            .AsNoTracking()
            .Where(x => x.Status == "Booked")
            .Where(x => x.StartTime < rangeEndExclusive && x.EndTime > rangeStart);

        if (!_isAdmin)
        {
            query = query.Where(x => x.ClientUserName == _currentUserName);
        }

        var rows = await query
            .Join(
                DbContext.ServiceOfferings.AsNoTracking(),
                appt => appt.ServiceOfferingId,
                svc => svc.Id,
                (appt, svc) => new
                {
                    appt.Id,
                    appt.StartTime,
                    appt.EndTime,
                    appt.ClientUserName,
                    ServiceName = svc.Name,
                    svc.DurationMinutes
                })
            .OrderBy(x => x.StartTime)
            .ToListAsync();

        _agendaItems = rows
            .Select(x => new AgendaBookingItem(x.Id, x.StartTime, x.EndTime, x.ServiceName, x.ClientUserName, x.DurationMinutes))
            .ToList();
    }

    private static List<AvailabilityEvent> BuildOpeningsForService(
        ServiceOffering service,
        IReadOnlyDictionary<DateOnly, HashSet<DateTime>> freeByDay)
    {
        var events = new List<AvailabilityEvent>();
        var requiredBlocks = Math.Max(1, (int)Math.Ceiling(service.DurationMinutes / 60.0));

        foreach (var (day, starts) in freeByDay)
        {
            var orderedStarts = starts.OrderBy(x => x).ToList();
            foreach (var start in orderedStarts)
            {
                var fits = true;
                for (var offset = 1; offset < requiredBlocks; offset++)
                {
                    if (!starts.Contains(start.AddHours(offset)))
                    {
                        fits = false;
                        break;
                    }
                }

                if (!fits)
                {
                    continue;
                }

                var end = start.AddMinutes(service.DurationMinutes);
                events.Add(new AvailabilityEvent(service.Id, start, end, $"{service.Name} ({service.DurationMinutes} min)"));
            }
        }

        return events;
    }

    private static List<AvailabilityEvent> BuildOpeningsForAdmin(
        IReadOnlyDictionary<DateOnly, HashSet<DateTime>> freeByDay)
    {
        var events = new List<AvailabilityEvent>();

        foreach (var starts in freeByDay.Values)
        {
            foreach (var start in starts.OrderBy(x => x))
            {
                events.Add(new AvailabilityEvent(0, start, start.AddHours(1), "Open block"));
            }
        }

        return events;
    }

    private List<AvailabilityEvent> GetEventsForDay(DateOnly day)
    {
        return _events
            .Where(x => DateOnly.FromDateTime(x.Start) == day)
            .OrderBy(slot => slot.Start)
            .ToList();
    }

    private List<AdminBookedAppointment> GetAdminAppointmentsForDay(DateOnly day)
    {
        return _adminBookedAppointments
            .Where(x => DateOnly.FromDateTime(x.Start) == day)
            .OrderBy(x => x.Start)
            .ToList();
    }

    private async Task BookAppointmentAsync(AvailabilityEvent opening)
    {
        if (opening.ServiceOfferingId == 0)
        {
            _bookingMessage = "Select a service first.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_currentUserName))
        {
            _bookingMessage = "Could not determine logged-in user.";
            return;
        }

        var hasConflict = await DbContext.Appointments
            .AnyAsync(x => x.Status == "Booked" && x.StartTime < opening.End && x.EndTime > opening.Start);

        if (hasConflict)
        {
            _bookingMessage = "That opening was just booked. Please choose another time.";
            await LoadAvailabilityAsync();
            return;
        }

        DbContext.Appointments.Add(new Appointment
        {
            ServiceOfferingId = opening.ServiceOfferingId,
            ClientUserName = _currentUserName,
            StartTime = opening.Start,
            EndTime = opening.End,
            Status = "Booked",
            CreatedUtc = DateTime.UtcNow
        });

        await DbContext.SaveChangesAsync();
        _bookingMessage = $"Booked {opening.Start:MMM d} at {opening.Start:h:mm tt}.";
        await LoadAvailabilityAsync();
        await LoadClientAppointmentsAsync();
        await LoadPastClientAppointmentsAsync();
        if (_isAdmin)
        {
            await LoadAdminBookedAppointmentsAsync();
        }
    }

    private async Task BeginAdminManageOpenAsync(AvailabilityEvent opening)
    {
        _adminManageAppointmentId = null;
        _adminManageStart = opening.Start;
        _adminManageMessage = "Open slot selected. Choose client and appointment type.";
        _isAdminManageModalOpen = true;

        if (_adminManageServiceId == 0)
        {
            _adminManageServiceId = _selectedServiceId;
        }

        if (_clients.Count == 0)
        {
            await LoadClientsAsync();
        }
    }

    private async Task BeginAdminManageExistingAsync(AdminBookedAppointment booking)
    {
        _adminManageAppointmentId = booking.AppointmentId;
        _adminManageStart = booking.Start;
        _adminManageMessage = "Existing appointment loaded. Update client/type or cancel it.";
        _isAdminManageModalOpen = true;

        if (_clients.Count == 0)
        {
            await LoadClientsAsync();
        }

        var client = _clients.FirstOrDefault(x => string.Equals(x.UserName, booking.ClientUserName, StringComparison.OrdinalIgnoreCase));
        _adminSelectedClientId = client?.Id ?? 0;

        var service = _services.FirstOrDefault(x => string.Equals(x.Name, booking.ServiceName, StringComparison.OrdinalIgnoreCase));
        _adminManageServiceId = service?.Id ?? _adminManageServiceId;
    }

    private Task BeginAdminManageExistingAsync(AgendaBookingItem booking)
    {
        return BeginAdminManageExistingAsync(new AdminBookedAppointment(
            booking.AppointmentId,
            booking.Start,
            booking.End,
            booking.Label,
            booking.ClientUserName));
    }

    private string GetAdminManageEndPreview()
    {
        if (_adminManageStart is null)
        {
            return "Choose a time slot.";
        }

        var service = _services.FirstOrDefault(x => x.Id == _adminManageServiceId);
        if (service is null)
        {
            return "Select service.";
        }

        var end = _adminManageStart.Value.AddMinutes(service.DurationMinutes);
        return end.ToString("dddd, MMM d h:mm tt");
    }

    private async Task SaveAdminManagedAppointmentAsync()
    {
        if (_adminManageStart is null)
        {
            _adminManageMessage = "Pick an event first.";
            return;
        }

        var client = _clients.FirstOrDefault(x => x.Id == _adminSelectedClientId);
        if (client is null)
        {
            _adminManageMessage = "Select a client.";
            return;
        }

        var service = _services.FirstOrDefault(x => x.Id == _adminManageServiceId);
        if (service is null)
        {
            _adminManageMessage = "Select an appointment type.";
            return;
        }

        var start = _adminManageStart.Value;
        var end = start.AddMinutes(service.DurationMinutes);

        Appointment row;
        if (_adminManageAppointmentId is int appointmentId)
        {
            row = await DbContext.Appointments.FirstOrDefaultAsync(x => x.Id == appointmentId) ?? new Appointment();
            if (row.Id == 0)
            {
                _adminManageMessage = "Selected appointment no longer exists.";
                return;
            }

            row.ServiceOfferingId = service.Id;
            row.ClientUserName = client.UserName;
            row.StartTime = start;
            row.EndTime = end;
            row.Status = "Booked";
        }
        else
        {
            row = new Appointment
            {
                ServiceOfferingId = service.Id,
                ClientUserName = client.UserName,
                StartTime = start,
                EndTime = end,
                Status = "Booked",
                CreatedUtc = DateTime.UtcNow
            };
            DbContext.Appointments.Add(row);
        }

        await DbContext.SaveChangesAsync();

        _adminManageAppointmentId = row.Id;
        _adminManageMessage = $"Saved appointment for {client.UserName}.";

        await LoadAvailabilityAsync();
        await LoadAdminBookedAppointmentsAsync();
    }

    private async Task CancelAdminManagedAppointmentAsync()
    {
        if (_adminManageAppointmentId is not int appointmentId)
        {
            return;
        }

        var row = await DbContext.Appointments.FirstOrDefaultAsync(x => x.Id == appointmentId && x.Status == "Booked");
        if (row is null)
        {
            _adminManageMessage = "Appointment not found or already canceled.";
            await LoadAdminBookedAppointmentsAsync();
            return;
        }

        row.Status = "Canceled";
        row.CanceledUtc = DateTime.UtcNow;
        row.CanceledByUserName = _currentUserName;
        await DbContext.SaveChangesAsync();

        _adminManageMessage = "Appointment canceled.";
        _adminManageAppointmentId = null;

        await LoadAvailabilityAsync();
        await LoadAdminBookedAppointmentsAsync();
    }

