    }

    private Task CloseAdminManageModal()
    {
        ClearAdminManageSelection();
        return Task.CompletedTask;
    }

    private async Task LoadClientAppointmentsAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentUserName))
        {
            _myAppointments = [];
            return;
        }

        var rows = await DbContext.Appointments
            .AsNoTracking()
            .Where(x => x.ClientUserName == _currentUserName)
            .Where(x => x.Status == "Booked")
            .Where(x => x.EndTime >= DateTime.Now)
            .Join(
                DbContext.ServiceOfferings.AsNoTracking(),
                appt => appt.ServiceOfferingId,
                svc => svc.Id,
                (appt, svc) => new
                {
                    appt.Id,
                    appt.StartTime,
                    appt.EndTime,
                    ServiceName = svc.Name
                })
            .OrderBy(x => x.StartTime)
            .ToListAsync();

        _myAppointments = rows
            .Select(x => new ClientBookingBlock(x.Id, x.StartTime, x.EndTime, x.ServiceName))
            .ToList();
    }

    private async Task LoadAdminBookedAppointmentsAsync()
    {
        var rangeStart = _rangeStart.ToDateTime(TimeOnly.MinValue);
        var rangeEndExclusive = _rangeEnd.AddDays(1).ToDateTime(TimeOnly.MinValue);

        var rows = await DbContext.Appointments
            .AsNoTracking()
            .Where(x => x.Status == "Booked")
            .Where(x => x.StartTime < rangeEndExclusive && x.EndTime > rangeStart)
            .Join(
                DbContext.ServiceOfferings.AsNoTracking(),
                appt => appt.ServiceOfferingId,
                svc => svc.Id,
                (appt, svc) => new
                {
                    appt.Id,
                    appt.StartTime,
                    appt.EndTime,
                    appt.ClientUserName,
                    ServiceName = svc.Name
                })
            .OrderBy(x => x.StartTime)
            .ToListAsync();

        _adminBookedAppointments = rows
            .Select(x => new AdminBookedAppointment(x.Id, x.StartTime, x.EndTime, x.ServiceName, x.ClientUserName))
            .ToList();
    }

    private async Task LoadPastClientAppointmentsAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentUserName))
        {
            _pastClientAppointments = [];
            _pastClientAppointmentsPage = 1;
            return;
        }

        var rows = await DbContext.Appointments
            .AsNoTracking()
            .Where(x => x.ClientUserName == _currentUserName)
            .Where(x => x.Status == "Booked")
            .Where(x => x.EndTime < DateTime.Now)
            .Join(
                DbContext.ServiceOfferings.AsNoTracking(),
                appt => appt.ServiceOfferingId,
                svc => svc.Id,
                (appt, svc) => new
                {
                    appt.Id,
                    appt.StartTime,
                    appt.EndTime,
                    ServiceName = svc.Name,
                    svc.DurationMinutes
                })
            .OrderByDescending(x => x.StartTime)
            .ToListAsync();

        _pastClientAppointments = rows
            .Select(x => new AgendaBookingItem(x.Id, x.StartTime, x.EndTime, x.ServiceName, _currentUserName, x.DurationMinutes))
            .ToList();

        _pastClientAppointmentsPage = 1;
    }

    private void PreviousPastAppointmentsPage()
    {
        if (_pastClientAppointmentsPage > 1)
        {
            _pastClientAppointmentsPage -= 1;
        }
    }

    private void NextPastAppointmentsPage()
    {
        if (_pastClientAppointmentsPage < PastAppointmentsTotalPages)
        {
            _pastClientAppointmentsPage += 1;
        }
    }

    private async Task CancelAppointmentAsync(int appointmentId)
    {
        if (appointmentId <= 0)
        {
            return;
        }

        var row = await DbContext.Appointments
            .FirstOrDefaultAsync(x => x.Id == appointmentId && x.ClientUserName == _currentUserName && x.Status == "Booked");

        if (row is null)
        {
            _bookingMessage = "Appointment not found or already canceled.";
            await LoadClientAppointmentsAsync();
            return;
        }

        row.Status = "Canceled";
        row.CanceledUtc = DateTime.UtcNow;
        row.CanceledByUserName = _currentUserName;
        await DbContext.SaveChangesAsync();

        _bookingMessage = $"Canceled appointment on {row.StartTime:MMM d} at {row.StartTime:h:mm tt}.";
        await LoadAvailabilityAsync();
        await LoadClientAppointmentsAsync();
        if (_isAdmin)
        {
            await LoadAdminBookedAppointmentsAsync();
        }
    }

    private static DateOnly StartOfBusinessWeek(DateOnly day)
    {
        var diff = ((int)day.DayOfWeek + 6) % 7;
        return day.AddDays(-diff);
    }

    private bool IsWithinRange(DateOnly day)
    {
        if (_isAdmin)
        {
            return day >= _rangeStart && day <= _rangeEnd;
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        return day >= today && day <= _rangeEnd;
    }

    private bool IsClientAtCurrentWeek()
    {
        if (_isAdmin)
        {
            return false;
        }

        var currentWeekStart = StartOfBusinessWeek(DateOnly.FromDateTime(DateTime.Today));
        return _rangeStart <= currentWeekStart;
    }

    private string GetDayClass(DateOnly day)
    {
        if (!IsWithinRange(day))
        {
            return "calendar-day is-outside";
        }

        if (day == DateOnly.FromDateTime(DateTime.Today))
        {
            return "calendar-day is-today";
        }

        return "calendar-day";
    }

    private string GetViewButtonClass(CalendarView view)
    {
        return _selectedView == view ? "toggle-btn is-active" : "toggle-btn";
    }

    private string GetClientBookingViewButtonClass(ClientBookingView view)
    {
        return _clientBookingView == view ? "toggle-btn is-active" : "toggle-btn";
    }

    private sealed record AvailabilityEvent(int ServiceOfferingId, DateTime Start, DateTime End, string Label);
    private sealed record ClientBookingBlock(int AppointmentId, DateTime Start, DateTime End, string ServiceName);
    private sealed record AdminBookedAppointment(int AppointmentId, DateTime Start, DateTime End, string ServiceName, string ClientUserName);
    private sealed record AgendaBookingItem(int AppointmentId, DateTime Start, DateTime End, string Label, string ClientUserName, int DurationMinutes);

    private enum CalendarView
    {
        Calendar,
        Agenda
    }

    private enum ClientBookingView
    {
        Upcoming,
        Past
    }
