@page "/admin-dashboard"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@using OneChairStudio.Data
@using OneChairStudio.Models
@inject AppDbContext DbContext

<PageTitle>Admin Dashboard</PageTitle>

<div class="admin-page">
    <header class="admin-head">
        <p class="admin-label">Admin</p>
        <h1>Dashboard</h1>
        <p>Set up services with price and duration for client booking.</p>
    </header>

    <section class="card-block">
        <div class="card-head">
            <strong>Services</strong>
            <button type="button" class="toggle-btn" @onclick="ToggleServices">
                @(_showServices ? "Collapse" : "Open")
            </button>
        </div>

        @if (_showServices)
        {
            <div class="card-body">
                <EditForm Model="_editService" OnValidSubmit="SaveServiceAsync" FormName="serviceForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="service-form-grid">
                        <div>
                            <label for="serviceName">Service Name</label>
                            <InputText id="serviceName" class="field" @bind-Value="_editService.Name" />
                        </div>
                        <div>
                            <label for="servicePrice">Price</label>
                            <InputNumber id="servicePrice" class="field" @bind-Value="_editService.Price" />
                        </div>
                        <div>
                            <label for="serviceDuration">Duration (minutes)</label>
                            <InputNumber id="serviceDuration" class="field" @bind-Value="_editService.DurationMinutes" />
                        </div>
                        <div class="service-active">
                            <label>
                                <InputCheckbox @bind-Value="_editService.IsActive" />
                                <span>Active</span>
                            </label>
                        </div>
                    </div>

                    <div class="service-actions">
                        <button type="submit" class="save-btn">@(_isEditing ? "Update Service" : "Add Service")</button>
                        @if (_isEditing)
                        {
                            <button type="button" class="cancel-btn" @onclick="ResetForm">Cancel Edit</button>
                        }
                    </div>
                </EditForm>

                @if (!string.IsNullOrWhiteSpace(_statusMessage))
                {
                    <p class="status-msg">@_statusMessage</p>
                }

                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Price</th>
                                <th>Duration</th>
                                <th>Active</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var service in _services)
                            {
                                <tr>
                                    <td>@service.Name</td>
                                    <td>@service.Price.ToString("C")</td>
                                    <td>@service.DurationMinutes min</td>
                                    <td>@(service.IsActive ? "Yes" : "No")</td>
                                    <td class="table-actions">
                                        <button type="button" @onclick="() => EditService(service)">Edit</button>
                                        <button type="button" class="danger" @onclick="() => DeleteServiceAsync(service.Id)">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </section>
</div>

@code {
    private readonly ServiceEditorModel _editService = new();
    private readonly List<ServiceOffering> _services = [];

    private bool _showServices = true;
    private bool _isEditing;
    private int? _editingId;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadServicesAsync();
    }

    private void ToggleServices()
    {
        _showServices = !_showServices;
    }

    private async Task LoadServicesAsync()
    {
        _services.Clear();

        var rows = await DbContext.ServiceOfferings
            .AsNoTracking()
            .OrderBy(x => x.Name)
            .ToListAsync();

        _services.AddRange(rows);
    }

    private void EditService(ServiceOffering service)
    {
        _editingId = service.Id;
        _isEditing = true;

        _editService.Name = service.Name;
        _editService.Price = service.Price;
        _editService.DurationMinutes = service.DurationMinutes;
        _editService.IsActive = service.IsActive;

        _statusMessage = null;
    }

    private async Task SaveServiceAsync()
    {
        if (_editService.DurationMinutes <= 0)
        {
            _statusMessage = "Duration must be greater than zero.";
            return;
        }

        if (_isEditing && _editingId is int editId)
        {
            var row = await DbContext.ServiceOfferings.FirstOrDefaultAsync(x => x.Id == editId);
            if (row is null)
            {
                _statusMessage = "Service not found.";
                return;
            }

            row.Name = _editService.Name.Trim();
            row.Price = _editService.Price;
            row.DurationMinutes = _editService.DurationMinutes;
            row.IsActive = _editService.IsActive;

            await DbContext.SaveChangesAsync();
            _statusMessage = "Service updated.";
        }
        else
        {
            DbContext.ServiceOfferings.Add(new ServiceOffering
            {
                Name = _editService.Name.Trim(),
                Price = _editService.Price,
                DurationMinutes = _editService.DurationMinutes,
                IsActive = _editService.IsActive
            });

            await DbContext.SaveChangesAsync();
            _statusMessage = "Service added.";
        }

        await LoadServicesAsync();
        ResetForm();
    }

    private async Task DeleteServiceAsync(int serviceId)
    {
        var row = await DbContext.ServiceOfferings.FirstOrDefaultAsync(x => x.Id == serviceId);
        if (row is null)
        {
            return;
        }

        var hasAppointments = await DbContext.Appointments.AnyAsync(x => x.ServiceOfferingId == serviceId);
        if (hasAppointments)
        {
            row.IsActive = false;
            await DbContext.SaveChangesAsync();
            _statusMessage = "Service has appointments. It was deactivated instead of deleted.";
            await LoadServicesAsync();
            return;
        }

        DbContext.ServiceOfferings.Remove(row);
        await DbContext.SaveChangesAsync();

        _statusMessage = "Service deleted.";
        await LoadServicesAsync();

        if (_editingId == serviceId)
        {
            ResetForm();
        }
    }

    private void ResetForm()
    {
        _isEditing = false;
        _editingId = null;

        _editService.Name = string.Empty;
        _editService.Price = 0;
        _editService.DurationMinutes = 60;
        _editService.IsActive = true;
    }

    private sealed class ServiceEditorModel
    {
        [Required]
        [MaxLength(120)]
        public string Name { get; set; } = string.Empty;

        [Range(0, 9999)]
        public decimal Price { get; set; }

        [Range(1, 600)]
        public int DurationMinutes { get; set; } = 60;

        public bool IsActive { get; set; } = true;
    }
}

<style>
    .admin-page {
        width: min(1080px, 94vw);
        margin: 0 auto;
        padding: 2.3rem 0 4rem;
    }

    .admin-label {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
        font-weight: 700;
        color: #84662b;
        margin-bottom: 0.55rem;
    }

    .admin-head h1 {
        font-family: "Fraunces", Georgia, serif;
        margin: 0;
    }

    .admin-head p {
        color: #5f6672;
        margin-top: 0.55rem;
    }

    .card-block {
        margin-top: 1rem;
        border: 1px solid #e7ebf3;
        border-radius: 14px;
        background: #fff;
    }

    .card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.8rem 0.9rem;
        border-bottom: 1px solid #edf0f6;
    }

    .card-body {
        padding: 0.9rem;
    }

    .service-form-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.6rem;
        align-items: end;
    }

    .service-form-grid label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }

    .field {
        width: 100%;
        border: 1px solid #d8dce8;
        border-radius: 10px;
        padding: 0.52rem 0.62rem;
    }

    .service-active label {
        display: inline-flex;
        gap: 0.4rem;
        align-items: center;
        font-weight: 600;
    }

    .service-actions {
        margin-top: 0.75rem;
        display: flex;
        gap: 0.55rem;
    }

    .toggle-btn,
    .save-btn,
    .cancel-btn,
    .table-actions button {
        border: 0;
        border-radius: 999px;
        padding: 0.52rem 0.85rem;
        font-weight: 700;
        cursor: pointer;
    }

    .toggle-btn,
    .cancel-btn {
        background: #f0f4fb;
        color: #314056;
    }

    .save-btn {
        background: linear-gradient(135deg, #ff6a5b, #ff4f7b);
        color: #fff;
    }

    .status-msg {
        margin: 0.6rem 0 0;
        color: #2d5a18;
        font-weight: 600;
    }

    .table-wrap {
        margin-top: 0.8rem;
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th,
    td {
        padding: 0.6rem;
        border-bottom: 1px solid #ecf0f6;
        text-align: left;
        font-size: 0.92rem;
    }

    .table-actions {
        display: flex;
        gap: 0.45rem;
    }

    .table-actions .danger {
        background: #fce8ec;
        color: #9f1f38;
    }

    @@media (max-width: 860px) {
        .service-form-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 620px) {
        .service-form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
