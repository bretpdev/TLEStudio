@page "/login"
@inject NavigationManager NavigationManager

<PageTitle>Client Login</PageTitle>

<div class="login-shell">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5 col-xl-4">
            <div class="card shadow-sm border-0 login-card">
                <div class="card-header login-card-header">
                    <p class="auth-eyebrow">Client Access</p>
                    <h1>Sign in to view availability</h1>
                    <p class="auth-subtitle">Use your username and password to access your calendar openings.</p>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                            <span>@_errorMessage</span>
                        </div>
                    }

                    <form method="post" action="/auth/login">
                        <div class="form-group mb-3">
                            <label for="username" class="form-label">Username</label>
                            <input id="username" name="username" type="text" class="form-control" required />
                        </div>

                        <div class="form-group mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input id="password" name="password" type="password" class="form-control" required />
                        </div>

                        <input type="hidden" name="returnUrl" value="@_returnUrl" />

                        <div class="d-grid">
                            <button type="submit" class="btn auth-btn">Login</button>
                        </div>
                    </form>

                    <div class="auth-help">
                        <p>Set your seeded login in Data/SeedData.cs (username and password).</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string? _errorMessage;
    private string _returnUrl = "/calendar";

    protected override void OnInitialized()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("error", out var errorFlag) && errorFlag.ToString() == "1")
        {
            _errorMessage = "Incorrect email or password.";
        }

        if (query.TryGetValue("returnUrl", out var returnUrl) && !string.IsNullOrWhiteSpace(returnUrl))
        {
            _returnUrl = returnUrl.ToString();
        }
    }
}

<style>
    .login-shell {
        width: min(980px, 94vw);
        margin: 0 auto;
        padding: 3.2rem 0 4rem;
    }

    .login-card {
        background: #fff;
        border: 1px solid #eceff4;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 18px 42px rgba(31, 36, 48, 0.11);
    }

    .login-card-header {
        background: linear-gradient(140deg, rgba(232, 213, 183, 0.35), rgba(255, 255, 255, 0.95));
        padding: 1.15rem 1.3rem;
        border-bottom: 1px solid #eceff4;
    }

    .auth-eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #84662b;
        font-size: 0.74rem;
        margin-bottom: 0.6rem;
        font-weight: 700;
    }

    .login-card h1 {
        font-family: "Fraunces", Georgia, serif;
        font-size: clamp(1.35rem, 3.2vw, 1.9rem);
        margin: 0;
    }

    .auth-subtitle {
        color: #5f6672;
        line-height: 1.6;
        margin: 0.5rem 0 0;
        font-size: 0.95rem;
    }

    .form-label {
        font-weight: 600;
        color: #1f2430;
    }

    .form-control {
        border: 1px solid #d7dce6;
        border-radius: 12px;
        padding: 0.75rem 0.85rem;
    }

    .form-control:focus {
        border-color: #84662b;
        box-shadow: 0 0 0 0.2rem rgba(132, 102, 43, 0.16);
    }

    .auth-btn {
        margin-top: 0.25rem;
        border: 0;
        border-radius: 999px;
        padding: 0.72rem 1rem;
        background: linear-gradient(135deg, #ff6a5b, #ff4f7b);
        color: #fff;
        font-weight: 700;
        cursor: pointer;
    }

    .auth-help {
        margin-top: 1rem;
        border-top: 1px solid #eceff4;
        padding-top: 0.8rem;
        color: #5f6672;
        font-size: 0.88rem;
    }

    .auth-help p {
        margin: 0;
    }
</style>
