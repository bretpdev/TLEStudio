@page "/"

<PageTitle>One Chair Studio</PageTitle>

<div class="home-page">
	<header class="hero">
		<div class="hero-logo-wrap reveal" style="--delay: 0s;">
			<img src="images/OneChairLogo.png" alt="One Chair Studio logo" class="logo-desktop" />
			<img src="images/OneChairSmallLogo.png" alt="One Chair Studio compact logo" class="logo-mobile" />
		</div>

		<p class="eyebrow reveal" style="--delay: 0.08s;">Modern Hair Studio</p>
		<h1 class="reveal" style="--delay: 0.16s;">Professional style with a vibrant edge</h1>
		<p class="subtitle reveal" style="--delay: 0.24s;">
			Precision cuts, dimensional color, and glossy finish work in a calm one-on-one studio experience.
			Think polished, playful, and 100% you.
		</p>

		<div class="hero-actions reveal" style="--delay: 0.32s;">
			<a class="btn-main" href="#book">Book Now</a>
			<a class="btn-ghost" href="#services">See Services</a>
		</div>

		<div class="quick-notes reveal" style="--delay: 0.4s;">
			<div class="note-card">
				<h3>Signature Color</h3>
				<p>Custom blonding, rich brunettes, and vivid accents with healthy-shine finish.</p>
			</div>
			<div class="note-card">
				<h3>Cut + Style</h3>
				<p>From sleek bobs to movement-rich layers tailored to your face shape and lifestyle.</p>
			</div>
			<div class="note-card">
				<h3>One-on-One Studio</h3>
				<p>Private chair experience with personal consultation from start to finish.</p>
			</div>
		</div>
	</header>

	<section id="services" class="section-block">
		<div class="section-head">
			<p class="section-label">Services</p>
			<h2>Fresh looks, elevated technique.</h2>
		</div>

		<div class="services-grid">
			<article class="service-card reveal" style="--delay: 0.05s;">
				<h3>Color Sessions</h3>
				<p>Root touch-ups, full color, lived-in balayage, and tonal glosses.</p>
				<span>Starting at $95</span>
			</article>
			<article class="service-card reveal" style="--delay: 0.1s;">
				<h3>Haircuts</h3>
				<p>Precision women’s cuts, dry shaping, and full style finish.</p>
				<span>Starting at $55</span>
			</article>
			<article class="service-card reveal" style="--delay: 0.15s;">
				<h3>Event Styling</h3>
				<p>Polished blowouts, curls, and occasion styling with hold that lasts.</p>
				<span>Starting at $65</span>
			</article>
		</div>
	</section>

	<section class="section-block showcase">
		<div class="showcase-text reveal" style="--delay: 0.08s;">
			<p class="section-label">Studio Vibe</p>
			<h2>Clean white space, bold energy.</h2>
			<p>
				Built around comfort and confidence: bright studio lighting, upbeat playlists,
				and thoughtful details that make every visit feel like a reset.
			</p>
		</div>
		<div class="showcase-features">
			<div class="feature-item reveal" style="--delay: 0.12s;">
				<div class="feature-icon">✨</div>
				<h3>Bright Lighting</h3>
				<p>Professional studio lighting shows true color in every angle.</p>
			</div>
			<div class="feature-item reveal" style="--delay: 0.16s;">
				<div class="feature-icon">🎵</div>
				<h3>Upbeat Vibe</h3>
				<p>Hand-picked playlists keep the energy positive and inspiring.</p>
			</div>
			<div class="feature-item reveal" style="--delay: 0.2s;">
				<div class="feature-icon">☕</div>
				<h3>Thoughtful Touch</h3>
				<p>Coffee, tea, and calm moments make every visit special.</p>
			</div>
		</div>
	</section>

	<section id="book" class="section-block book-block">
		<div class="section-head">
			<p class="section-label">Book</p>
			<h2>Ready for your next hair day?</h2>
		</div>

		<div class="book-grid">
			<article class="contact-card reveal" style="--delay: 0.05s;">
				<h3>Contact</h3>
				<p>Email: hello@onechairstudio.com</p>
				<p>Phone: (555) 123-4567</p>
				<p>Location: Downtown Studio Suite</p>
			</article>
			<article class="contact-card reveal" style="--delay: 0.1s;">
				<h3>Hours</h3>
				<p>Tue-Thu: 10:00 AM - 7:00 PM</p>
				<p>Fri: 9:00 AM - 6:00 PM</p>
				<p>Sat: 9:00 AM - 3:00 PM</p>
			</article>
			<article class="contact-card accent reveal" style="--delay: 0.15s;">
				<h3>New Guest Offer</h3>
				<p>Complimentary gloss upgrade with your first cut + color service.</p>
				<a href="mailto:hello@onechairstudio.com" class="text-link">Claim by email</a>
			</article>
		</div>
	</section>
</div>

<style>
	:root {
		--ink: #1f2430;
		--muted: #5f6672;
		--line: #eceff4;
		--sunset: #ff6a5b;
		--citrus: #ffb347;
		--mint: #3fd1b4;
		--berry: #ff4f7b;
	}

	.home-page {
		width: min(1120px, 92vw);
		margin: 0 auto;
		padding: 2.5rem 0 4.5rem;
		color: var(--ink);
	}

	.hero {
		text-align: center;
		padding: 0.5rem 0 1rem;
	}

	.hero-logo-wrap {
		position: relative;
		margin: 0 auto 1rem;
		padding: 1.85rem;
		border-radius: 4px;
		width: fit-content;
		background: #fff;
		border: 2px solid #84662b;
		overflow: visible;
		box-shadow: 
			0 24px 46px rgba(31, 36, 48, 0.12),
			0 7px 14px rgba(31, 36, 48, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.9);
	}

	.hero-logo-wrap::before {
		content: "";
		position: absolute;
		inset: -10px -10px auto auto;
		width: 48%;
		height: 1px;
		background: linear-gradient(90deg, rgba(232, 213, 183, 0), rgba(232, 213, 183, 0.95));
		pointer-events: none;
		z-index: 2;
	}

	.hero-logo-wrap::after {
		content: "";
		position: absolute;
		left: -10px;
		top: 12px;
		width: 1px;
		height: 48%;
		background: linear-gradient(180deg, rgba(232, 213, 183, 0.95), rgba(232, 213, 183, 0));
		z-index: -1;
	}

	.logo-desktop,
	.logo-mobile {
		display: block;
		margin: 0 auto;
		height: auto;
		filter: saturate(1.04) contrast(1.01);
		position: relative;
		z-index: 1;
	}

	.logo-desktop {
		width: min(460px, 82vw);
	}

	.logo-mobile {
		width: min(220px, 68vw);
		display: none;
	}

	.eyebrow,
	.section-label {
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--berry);
		margin-bottom: 0.75rem;
	}

	h1,
	h2,
	h3 {
		font-family: "Fraunces", Georgia, serif;
	}

	h1 {
		font-size: clamp(2rem, 5vw, 3.4rem);
		line-height: 1.1;
		margin: 0;
		display: inline-block;
		padding: 0.45rem 1rem 0.55rem;
		border-radius: 18px;
		border: 1px solid transparent;
		background:
			linear-gradient(#ffffff, #ffffff) padding-box,
			linear-gradient(120deg, rgba(255, 106, 91, 0.6), rgba(255, 79, 123, 0.55), rgba(63, 209, 180, 0.5)) border-box;
		box-shadow: 0 8px 22px rgba(31, 36, 48, 0.08);
	}

	.subtitle {
		max-width: 740px;
		margin: 1rem auto 0;
		color: var(--muted);
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.hero-actions {
		margin-top: 1.8rem;
		display: flex;
		justify-content: center;
		gap: 0.9rem;
		flex-wrap: wrap;
	}

	.btn-main,
	.btn-ghost {
		border-radius: 999px;
		padding: 0.82rem 1.4rem;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.btn-main {
		color: #fff;
		background: linear-gradient(135deg, var(--sunset), var(--berry));
		box-shadow: 0 12px 28px rgba(255, 79, 123, 0.24);
	}

	.btn-ghost {
		color: var(--ink);
		background: #fff;
		border: 1px solid var(--line);
	}

	.btn-main:hover,
	.btn-ghost:hover {
		transform: translateY(-2px);
	}

	.quick-notes {
		margin-top: 2.1rem;
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.note-card,
	.service-card,
	.contact-card {
		border: 1px solid var(--line);
		border-radius: 18px;
		background: #fff;
		padding: 1.1rem;
	}

	.note-card {
		background:
			linear-gradient(#fff, #fff) padding-box,
			linear-gradient(120deg, rgba(255, 106, 91, 0.4), rgba(63, 209, 180, 0.4)) border-box;
		border: 1px solid transparent;
	}

	.note-card h3,
	.service-card h3,
	.contact-card h3 {
		margin: 0 0 0.45rem;
		font-size: 1.3rem;
	}

	.note-card p,
	.service-card p,
	.contact-card p,
	.showcase-text p {
		color: var(--muted);
		margin-bottom: 0;
		line-height: 1.6;
	}

	.section-block {
		padding-top: 3.5rem;
	}

	.section-head {
		margin-bottom: 1.3rem;
	}

	.section-head h2 {
		margin: 0;
		font-size: clamp(1.6rem, 3vw, 2.4rem);
	}

	.services-grid,
	.book-grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.service-card {
		position: relative;
		overflow: hidden;
	}

	.service-card::after {
		content: "";
		position: absolute;
		inset: auto auto -35px -30px;
		width: 120px;
		height: 120px;
		border-radius: 999px;
		background: radial-gradient(circle at center, rgba(255, 179, 71, 0.28), rgba(255, 179, 71, 0));
	}

	.service-card span {
		display: inline-block;
		margin-top: 0.85rem;
		color: var(--sunset);
		font-weight: 700;
	}

	.showcase {
		display: grid;
		grid-template-columns: 1fr 1.15fr;
		gap: 1.2rem;
		align-items: center;
	}

	.showcase-features {
		display: grid;
		gap: 1rem;
		grid-template-columns: 1fr;
	}

	.feature-item {
		border: 1px solid var(--line);
		border-radius: 18px;
		background: #fff;
		padding: 1.4rem;
		text-align: center;
	}

	.feature-icon {
		font-size: 2.2rem;
		margin-bottom: 0.7rem;
		display: block;
	}

	.feature-item h3 {
		margin: 0 0 0.5rem;
		font-size: 1.15rem;
		color: var(--ink);
	}

	.feature-item p {
		color: var(--muted);
		margin: 0;
		line-height: 1.6;
		font-size: 0.95rem;
	}

	.contact-card.accent {
		background: linear-gradient(160deg, #fff2ea, #fff8ef 60%, #ffffff);
		border-color: #ffd8c4;
	}

	.text-link {
		display: inline-block;
		margin-top: 0.8rem;
		color: var(--berry);
		font-weight: 700;
		text-decoration: none;
	}

	.reveal {
		opacity: 0;
		transform: translateY(16px);
		animation: revealIn 600ms ease forwards;
		animation-delay: var(--delay, 0s);
	}

	@@keyframes revealIn {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@@media (max-width: 900px) {
		.quick-notes,
		.services-grid,
		.book-grid {
			grid-template-columns: 1fr 1fr;
		}

		.showcase {
			grid-template-columns: 1fr;
		}

		.showcase-features {
			grid-template-columns: 1fr;
		}
	}

	@@media (max-width: 680px) {
		.home-page {
			width: min(100%, 95vw);
			padding-top: 1.75rem;
		}

		.hero-logo-wrap {
			padding: 1.15rem;
			border-radius: 4px;
		}

		.logo-desktop {
			display: none;
		}

		.logo-mobile {
			display: block;
		}

		.quick-notes,
		.services-grid,
		.book-grid {
			grid-template-columns: 1fr;
		}

		.hero-actions {
			width: 100%;
		}

		.btn-main,
		.btn-ghost {
			width: min(300px, 100%);
			text-align: center;
		}
	}
</style>
